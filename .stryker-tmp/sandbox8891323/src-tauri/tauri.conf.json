{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/nicegui/static/tauri.conf.schema.json",
  "productName": "BES Book Formatter",
  "version": "0.1.0",
  "identifier": "com.corgnati.bes-book-formatter",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "title": "BES Book Formatter",
    "windows": [
      {
        "label": "main",
        "title": "BES Book Formatter",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: tauri: data:; font-src 'self' asset:; connect-src 'self' ipc: tauri:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/typst",
      "binaries/ghostscript",
      "binaries/epubcheck"
    ]
  },
  "plugins": {
    "sql": {
      "preload": {
        "db": "sqlite:bes-book-formatter.db"
      }
    },
    "shell": {
      "sidecar": true,
      "scope": [
        { "name": "binaries/typst", "sidecar": true },
        { "name": "binaries/ghostscript", "sidecar": true },
        { "name": "binaries/epubcheck", "sidecar": true }
      ]
    }
  }
}
