# ============================================
# VARIAVEIS DE AMBIENTE - BES BOOK FORMATTER
# ============================================
# EXEMPLO - Copie para .env e preencha os valores
# Stack: SvelteKit + Rust Axum + Tauri + SQLite
# ============================================

# ────────────────────────────────────────────
# AMBIENTE
# ────────────────────────────────────────────
NODE_ENV=development

# ────────────────────────────────────────────
# LOGGING (Rust)
# ────────────────────────────────────────────
# RUST_LOG — Nivel de logging para env_logger
# Recomendado para dev: "bes_book_formatter=debug"
# Valores: off, error, warn, info, debug, trace
RUST_LOG=info

# ────────────────────────────────────────────
# CACHE (BES Sync Service)
# ────────────────────────────────────────────
# CACHE_TTL_MINUTES — Tempo de vida do cache (minutos)
# Default: 5 minutos
CACHE_TTL_MINUTES=5

# ────────────────────────────────────────────
# DATABASE
# ────────────────────────────────────────────
# DATABASE_NAME — Nome da base SQLite
DATABASE_NAME=bes-book-formatter

# ────────────────────────────────────────────
# TAURI
# ────────────────────────────────────────────
# TAURI_DEV_URL — URL do servidor dev
TAURI_DEV_URL=http://localhost:1420

# ────────────────────────────────────────────
# BUILD / PRODUCAO (opcional)
# ────────────────────────────────────────────
# VITE_API_BASE=http://localhost:3000
