{
  "name": "bes-book-formatter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "./scripts/bootstrap.sh",
    "reset": "./scripts/bootstrap.sh --reset",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint src --ext .ts,.svelte",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:mutation": "stryker run",
    "test:mutation:incremental": "stryker run --incremental",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "db:seed": "bash scripts/seed.sh",
    "db:reset": "bash scripts/seed.sh --reset",
    "docker:dev": "docker compose run --rm dev",
    "docker:watch": "docker compose up dev-watch",
    "docker:test": "docker compose run --rm test-rust",
    "docker:build": "docker compose run --rm build-release",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down -v"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-sql": "^2.0.0",
    "@tauri-apps/plugin-store": "^2.0.0",
    "lucide-svelte": "^0.454.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@sveltejs/adapter-static": "^0.0.17",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "jsdom": "^29.0.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  },
  "type": "module"
}
