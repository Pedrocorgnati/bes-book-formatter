{
  "identifier": "default",
  "description": "Default capabilities for BES Book Formatter",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "dialog:default",
    "store:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "scope": {
        "allow": [
          { "name": "typst",       "cmd": "typst",  "args": true, "sidecar": false },
          { "name": "ghostscript", "cmd": "gs",     "args": true, "sidecar": false },
          { "name": "pandoc",      "cmd": "pandoc", "args": true, "sidecar": false },
          { "name": "java",        "cmd": "java",   "args": true, "sidecar": false },
          { "name": "which",       "cmd": "which",  "args": true, "sidecar": false }
        ]
      }
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$RESOURCE/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$APPDATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$APPDATA/**" }
      ]
    }
  ]
}
