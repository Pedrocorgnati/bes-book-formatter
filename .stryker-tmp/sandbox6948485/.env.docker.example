# BES Book Formatter — .env.docker.example
# Copiar para .env.docker e preencher os valores
# Este arquivo PODE ser versionado (sem valores sensíveis)

NODE_ENV=development
VITE_APP_NAME="BES Book Formatter"
VITE_APP_VERSION=0.1.0

# Tauri signing (opcional para dev local)
TAURI_PRIVATE_KEY=
TAURI_KEY_PASSWORD=

RUST_LOG=debug
RUST_BACKTRACE=1
DATABASE_URL=sqlite://test.db
